{
  "name": "anvil-ai",
  "version": "0.1.11",
  "description": "Lightweight AI Code Factory — Build anything from a single command. Pure TypeScript, zero setup.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "anvil": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "autonomous-agents",
    "code-generation",
    "typescript",
    "claude",
    "cli",
    "developer-tools",
    "forge"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fepvenancio/anvil.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^8.2.0",
    "p-limit": "^6.2.0",
    "pino": "^9.6.0",
    "simple-git": "^3.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
